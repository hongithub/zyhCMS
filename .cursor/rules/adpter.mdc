#### 4. MariaDB Schema (`{ModuleName}Schema.js`)

```javascript
/**
 * {ModuleName} MariaDB 表结构定义
 */
'use strict';

const { DataTypes } = require('sequelize');

module.exports = (sequelize) => {
  const {ModuleName}Schema = sequelize.define('{moduleName}', {
    id: {
      type: DataTypes.INTEGER,
      primaryKey: true,
      autoIncrement: true,
    },
    mongo_id: {
      type: DataTypes.STRING(24),
      unique: true,
      allowNull: true,
      comment: 'MongoDB _id 映射',
    },
    // ... 其他字段定义
    created_at: {
      type: DataTypes.DATE,
      defaultValue: DataTypes.NOW,
    },
    updated_at: {
      type: DataTypes.DATE,
      defaultValue: DataTypes.NOW,
    },
  }, {
    tableName: 'dora_{moduleName}s',
    timestamps: true,
    createdAt: 'created_at',
    updatedAt: 'updated_at',
  });

  return {ModuleName}Schema;
};
```

#### 5. 新的业务服务层 (`{moduleName}New.js`)

```javascript
/**
 * {ModuleName} 新业务服务层
 * 使用 Repository 模式，支持多数据库
 */
'use strict';

const RepositoryFactory = require('../repository/factories/RepositoryFactory');

class {ModuleName}Service {
  constructor(ctx) {
    this.ctx = ctx;
    this.repository = RepositoryFactory.create('{ModuleName}', ctx);
  }

  // 业务方法实现
  async find(payload, options) {
    return await this.repository.find(payload, options);
  }

  async create(data) {
    return await this.repository.create(data);
  }

  // ... 其他业务方法
}

module.exports = {ModuleName}Service;
```

### 🧪 测试文件规范

#### 功能测试文件 (`test-{moduleName}-repository.js`)

```javascript
/**
 * {ModuleName} Repository 功能验证测试脚本
 * 直接创建 Repository 实例，不依赖完整 EggJS 应用
 */
'use strict';

// 设置测试环境变量
process.env.NODE_ENV = 'test';
// ... 数据库连接配置

const {ModuleName}MongoRepository = require('../../app/repository/adapters/mongodb/{ModuleName}MongoRepository');
const {ModuleName}MariaRepository = require('../../app/repository/adapters/mariadb/{ModuleName}MariaRepository');

// 模拟 EggJS 上下文
const mockApp = {
  config: {
    encrypt_key: process.env.ENCRYPT_KEY,
    database: { type: 'mongodb' },
    repository: { databaseType: 'mongodb' },
  },
  logger: console,
};

const mockCtx = {
  app: mockApp,
  model: {},
  requestId: 'test-' + Date.now(),
};

class {ModuleName}RepositoryTester {
  constructor() {
    this.mongoRepo = null;
    this.mariaRepo = null;
    this.testResults = {
      mongodb: { passed: 0, failed: 0, errors: [] },
      mariadb: { passed: 0, failed: 0, errors: [] },
    };
  }

  async initialize() {
    // 初始化 Repository 实例
    this.mongoRepo = new {ModuleName}MongoRepository(mockCtx);
    this.mariaRepo = new {ModuleName}MariaRepository(mockCtx);
  }

  async runTests() {
    // 测试基础 CRUD 方法
    await this.testBasicCRUD(this.mongoRepo, 'mongodb');
    await this.testBasicCRUD(this.mariaRepo, 'mariadb');

    // 测试模块特有业务方法
    await this.testBusinessMethods(this.mongoRepo, 'mongodb');
    await this.testBusinessMethods(this.mariaRepo, 'mariadb');

    // 显示测试结果
    this.showTestResults();
  }

  // ... 具体测试方法实现
}

// 运行测试
async function runAllTests() {
  const tester = new {ModuleName}RepositoryTester();
  await tester.runTests();
}

if (require.main === module) {
  runAllTests().catch(console.error);
}
```

