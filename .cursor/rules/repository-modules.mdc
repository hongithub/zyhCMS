'use strict';

const { DataTypes } = require('sequelize');

/**
 * {ModuleName} Schema for MariaDB
 * {ModuleName}表结构定义 - 基于 MongoDB 模型设计
 */
const {ModuleName}Schema = (sequelize, app) => {
  const {ModuleName} = sequelize.define(
    '{moduleName}',
    {
      id: {
        type: DataTypes.INTEGER,
        primaryKey: true,
        autoIncrement: true,
        comment: '主键ID',
      },

      // 🔥 核心字段（与 MongoDB 模型一致，参考Menu模块）
      name: {
        type: DataTypes.STRING(100),
        allowNull: false,
        comment: '名称',
        validate: {
          notEmpty: true,
          len: [1, 100],
        },
      },

      // title: {
