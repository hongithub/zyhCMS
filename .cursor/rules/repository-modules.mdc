  // async buildTree(dataList, parentId = 0) { ... }
  // async batchUpdateStatus(ids, status) { ... }

  // ===== 辅助方法 =====

  /**
   * 构建搜索条件（注意参数顺序）
   * @private
   */
  _buildSearchCondition(searchKeys, keyword) {
    if (!keyword || !searchKeys.length) {
      return {};
    }

    const conditions = searchKeys.map(key => ({
      [key]: { [this.Op.like]: `%${keyword}%` },
    }));

    return {
      [this.Op.or]: conditions,
    };
  }

