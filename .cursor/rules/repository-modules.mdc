    }
  );

  // 定义关联关系
  {ModuleName}.associate = models => {
    // 添加关联关系，例如：
    // {ModuleName}.belongsTo(app.model.User, { foreignKey: 'authorId', as: 'author' });
    // {ModuleName}.belongsTo(app.model.Category, { foreignKey: 'categoryId', as: 'category' });
    // 通常标签等是被其他实体引用的，所以这里可能不需要定义关联
    // 如果需要统计关联的内容数量，可以定义 hasMany 关系
  };

  // 🔥 类方法（基于Menu模块经验）
  {ModuleName}.findByStatus = function (status) {
    return this.findAll({ where: { status } });
  };

  {ModuleName}.findByName = function (name) {
    return this.findOne({ where: { name } });
  };

  {ModuleName}.findByParentId = function (parentId) {
    return this.findAll({
      where: { parentId },
      order: [
        ['order', 'ASC'],
        ['createdAt', 'DESC'],
      ],
    });
  };

  {ModuleName}.findEnabledItems = function () {
    return this.findAll({
      where: { status: '1' },
      order: [
        ['order', 'ASC'],
        ['createdAt', 'DESC'],
      ],
    });
  };

  {ModuleName}.checkNameUnique = async function (name, excludeId = null) {
    const where = { name };
    if (excludeId) {
      where.id = { [sequelize.Sequelize.Op.ne]: excludeId };
    }
    const count = await this.count({ where });
    return count === 0;
  };

  // 🔥 实例方法（基于Menu模块成功实践）
  {ModuleName}.prototype.toJSON = function () {
    const values = Object.assign({}, this.get());

    // 添加虚拟 URL 字段
    values.url = `/{moduleName}/${values.name || values.id}`;

    // 🔥 格式化日期（使用 moment 格式化）
    if (values.createdAt) {
      const moment = require('moment');
      values.createdAt = moment(values.createdAt).format('YYYY-MM-DD HH:mm:ss');
    }
    if (values.updatedAt) {
      const moment = require('moment');
      values.updatedAt = moment(values.updatedAt).format('YYYY-MM-DD HH:mm:ss');
    }

    // 🔥 添加状态文本描述
    values.statusText = values.status === '1' ? '启用' : '禁用';

    return values;
  };

  {ModuleName}.prototype.getDisplayName = function () {
    return this.name || `{ModuleName}-${this.id}`;
  };

  {ModuleName}.prototype.isEnabled = function () {
    return this.status === '1';
  };

  {ModuleName}.prototype.isDisabled = function () {
    return this.status === '0';
  };

