  "engines": {
    "node": ">=14.0.0",
    "pnpm": ">=8"
  },
  "scripts": {
    "debug": "egg-bin debug --port=8080",
    "dev": "cross-env NODE_ENV=development egg-bin dev --sticky --port=8080",
    "test": "npm run lint -- --fix && npm run test-local",
    "test-local": "egg-bin test",
    "cov": "egg-bin cov",
    "lint": "eslint .",
    "ci": "npm run lint && npm run cov",
    "autod": "autod",
    "init": "node ./build/restore",
    "doracms": "node ./install/index.js",
    "start": "cross-env NODE_ENV=production egg-scripts start --daemon --title=doracms3 --sticky",
    "stop": "egg-scripts stop --title=doracms3",
    "clean": "rm -rf node_modules pnpm-lock.yaml && pnpm -r exec rm -rf node_modules",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "generate-permissions": "node scripts/generate-permissions.js",
    "preinstall": "npx only-allow pnpm",
    "plugin:install": "pnpm install --filter \"./lib/plugin/*\"",
    "plugin:clean": "pnpm -r --filter ./lib/plugin/* exec rm -rf node_modules",
    "plugin:build": "pnpm -r --filter ./lib/plugin/* run build",
    "plugin:test": "pnpm -r --filter ./lib/plugin/* run test",
    "test-env": "node scripts/test-env.js",
    "check-worker": "node scripts/check-worker-config.js",
    "db:init": "node scripts/init-database.js",
    "db:init:force": "node scripts/init-database.js --force"
  },
  "ci": {
    "version": "8, 9"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "egg",
    "egg-framework"
  ],
  "author": "doramart",
  "files": [
    "app",
    "config",
    "lib",
    "index.js"
  ],
  "eslintIgnore": [
    "coverage",
    "dist"
  ],
