    "autod-egg": "^1.1.0",
    "egg-bin": "^5.11.1",
    "egg-ci": "^2.2.0",
    "egg-mock": "^5.10.0",
    "eslint": "^8.54.0",
    "eslint-config-egg": "^12.2.1",
    "eslint-config-prettier": "^9.0.0",
