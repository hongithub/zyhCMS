# =================================
# 服务器基础配置
# =================================
NODE_ENV=production
PORT=8080
HOSTNAME=127.0.0.1
DATABASE_TYPE=mongodb
REPOSITORY_ENABLED=true

# =================================
# 数据库自动初始化配置
# =================================
# 跳过数据库初始化（默认 false）
# DB_SKIP_INIT=false

# 强制重新初始化数据库（会清空敏感数据表，默认 false）
# DB_FORCE_INIT=false

# Worker 进程数量（默认1，推荐值：CPU核心数）
# 2核服务器建议配置 1-2 个 worker
EGG_WORKERS=1

# =================================
# 数据库配置
# =================================
# MongoDB Root 用户（用于初始化）
MONGODB_ROOT_USERNAME=admin
MONGODB_ROOT_PASSWORD=admin123

# MongoDB 应用用户
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_USERNAME=your_username
MONGODB_PASSWORD=your_password
MONGODB_DATABASE=doracms3
MONGODB_AUTH_SOURCE=admin

# Mariadb 配置
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3307
MARIADB_DATABASE=doracms3
MARIADB_USERNAME=root
MARIADB_PASSWORD=123456

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =================================
# 缓存配置
# =================================
# 缓存类型：memory（内存缓存，默认） | redis（Redis缓存）
CACHE_TYPE=memory
# 缓存默认过期时间（秒）
CACHE_DEFAULT_TTL=3600
# 内存缓存最大条目数
MEMORY_CACHE_MAX_SIZE=1000
# 缓存命名空间（默认：{应用名}:{NODE_ENV}）
CACHE_NAMESPACE=cms3:production
# 是否启用缓存 watch（跨进程同步）
CACHE_WATCH_ENABLED=true
# watch 消息通道名称
CACHE_WATCH_CHANNEL=unified-cache:watch
# watch 是否传播缓存值（用于多实例同步）
CACHE_WATCH_BROADCAST_VALUE=true
# 权限热加载开关
PERMISSION_HOT_RELOAD_ENABLED=true
# 权限热加载轮询间隔（毫秒）
PERMISSION_HOT_RELOAD_INTERVAL=5000

# =================================
# 安全配置
# =================================
# 应用密钥（用于 Cookie 加密，生产环境必须修改）
APP_KEYS=your_app_secret_key

# Session 密钥（用于密码重置令牌生成，生产环境必须修改）
SESSION_SECRET=doracms_secret

# 认证 Cookie 名称
AUTH_COOKIE_NAME=doracms

# 加密密钥（用于密码加密和邮件密码解密，生产环境必须修改）
# 注意：修改此配置后，需要重新设置所有用户密码和系统邮箱密码
ENCRYPT_KEY=dora

# JWT 签名密钥（用于 admin/user Bearer Token，生产环境必须单独配置，且不能与 ENCRYPT_KEY 相同）
JWT_SECRET=

# JWT Token 过期时间（默认 30 天）
JWT_EXPIRES_IN=30day

# 初始化超级管理员的保护配置
# ADMIN_INIT_LOCAL_ONLY=true 表示仅允许从服务器本机访问初始化接口
ADMIN_INIT_LOCAL_ONLY=true
# 如需远程初始化，请设置一个高强度令牌，并在请求头中携带 x-admin-init-token
ADMIN_INIT_TOKEN=


# =================================
# 文件存储配置
# =================================
# 文件上传路径
UPLOAD_PATH=/path/to/upload/directory
STATIC_PATH=/path/to/static/directory


# 日志路径
LOG_DIR=/path/to/logs/directory
LOG_LEVEL=INFO

# =================================
# 第三方服务配置
# =================================
# CDN 配置
CDN_ORIGIN=https://cdn.html-js.cn
API_DOMAIN=https://api.html-js.cn

# =================================
# CORS 和安全配置
# =================================
# 允许的域名（用逗号分隔）
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
DOMAIN_WHITELIST=https://your-domain.com,https://www.your-domain.com 
