{
  "name": "egg-dora-middlestage",
  "version": "1.0.0",
  "description": "egg plugin for doracms middlestage management",
  "private": false,
  "main": "app.js",
  "eggPlugin": {
    "name": "doraMiddleStage"
  },
  "keywords": [
    "egg",
    "eggPlugin",
    "egg-plugin",
    "doracms",
    "middlestage"
  ],
  "dependencies": {
    "egg": "^3.30.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "shortid": "^2.2.16",
    "validator": "^13.11.0"
  },
  "peerDependencies": {
    "egg": ">=3.30.1"
  },
  "devDependencies": {
    "autod": "^3.1.2",
    "egg-bin": "^5.11.1",
    "egg-ci": "^2.2.0",
    "egg-mock": "^5.10.0",
    "eslint": "^8.54.0",
    "eslint-config-egg": "^12.2.1"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "test": "npm run lint -- --fix && npm run test-local",
    "test-local": "egg-bin test",
