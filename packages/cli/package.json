{
  "name": "doracms-cli",
  "version": "0.1.3",
  "description": "DoraCMS CLI - 项目脚手架和开发工具",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "doracms": "bin/doracms.js"
  },
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "build": "npm run build:cli && npm run build:templates",
    "build:cli": "tsup src/index.ts --format cjs,esm --dts",
    "build:templates": "node scripts/build-templates.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "doracms",
    "cli",
    "scaffold",
    "generator"
  ],
  "author": "DoraCMS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/doramart/doracms",
    "directory": "packages/cli"
  },
  "dependencies": {
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "ejs": "^3.1.9",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1",
    "semver": "^7.5.4",
    "update-notifier": "^7.0.0",
    "validate-npm-package-name": "^5.0.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.10.6",
    "@types/semver": "^7.5.6",
    "@types/update-notifier": "^6.0.8",
    "@types/validate-npm-package-name": "^4.0.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
